# Groq API key (required for summarization)
GROQ_API_KEY=

# Stripe (required for paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=   # $19/mo price ID from Stripe dashboard
STRIPE_PRO_PRICE_ID=     # $49/mo price ID from Stripe dashboard

# Resend (required for watchlist email alerts)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com

# App URL (used in email links, set to your deployed URL)
APP_URL=http://localhost:8000
